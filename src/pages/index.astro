---
import Base from "../layouts/Base.astro";
import Card from "../components/Card.astro";
import { CATEGORIES } from "../data/categories.js";
import { items as allItems } from "../lib/items.js";

const items = [...allItems].sort((a, b) => (a.date < b.date ? 1 : -1));
const cats = Object.entries(CATEGORIES);
---
<Base
  title="americawhat — wait, what"
  description="A curated running feed of absurd, deeply-American moments. The strange, the everyday, the unbelievable — for the times that make you stop and go wait, what."
  canonicalPath="/"
>
  <section class="hero" aria-label="americawhat" slot="hero">
    <div class="hero-inner">
      <div class="hero-eyebrow">A running feed of the deeply American</div>
      <h1 class="hero-title">
        <span class="hero-america">America,</span>
        <span class="hero-second"><span class="hero-word">what</span><span class="hero-q">?</span></span>
      </h1>
      <p class="hero-lede">The strange, the everyday, the unbelievably American. The moments that make you stop and go <em>wait, what.</em></p>
    </div>
  </section>

  <section class="trending" id="trending" hidden>
    <div class="trending-head"><span class="trending-flag">Trending</span> — most-reacted right now</div>
    <ol class="trending-list" id="trending-list"></ol>
  </section>

  <nav class="cat-bar" aria-label="Filter by category">
    <button class="cat-chip active" data-filter="all" aria-pressed="true">All</button>
    {cats.map(([key, c]) => (
      <button class="cat-chip" data-filter={key} aria-pressed="false">{c.label}</button>
    ))}
  </nav>

  <section class="feed" id="feed">
    {items.map((item) => <Card item={item} />)}
  </section>

  <p class="empty" id="empty" style="display:none">Nothing here in this category yet. Check back soon.</p>

  <script>
    // ── Category filter (feed page only) ──
    const chips = document.querySelectorAll(".cat-chip");
    const cards = Array.from(document.querySelectorAll(".card"));
    const emptyEl = document.getElementById("empty");
    chips.forEach((chip) => {
      chip.addEventListener("click", () => {
        chips.forEach((c) => {
          c.classList.remove("active");
          c.setAttribute("aria-pressed", "false");
        });
        chip.classList.add("active");
        chip.setAttribute("aria-pressed", "true");
        const f = chip.getAttribute("data-filter");
        let visible = 0;
        cards.forEach((card) => {
          const show = f === "all" || card.getAttribute("data-category") === f;
          card.style.display = show ? "" : "none";
          if (show) visible++;
        });
        if (emptyEl) emptyEl.style.display = visible === 0 ? "block" : "none";
      });
    });
  </script>

  <script>
    // ── Trending: top-5 by total reactions (client-side, live) ──
    (async function () {
      const cards = Array.from(document.querySelectorAll(".card[data-id]"));
      if (!cards.length) return;
      const ids = cards.map((c) => c.dataset.id).filter(Boolean);
      let data = {};
      try {
        const res = await fetch("/analytics/get_votes.php?ids=" + ids.join(","));
        data = await res.json();
      } catch (e) {
        return;
      }
      const esc = (s) =>
        String(s).replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]));
      const rows = [];
      cards.forEach((c) => {
        const id = c.dataset.id;
        const link = c.querySelector(".title-link");
        if (!link) return;
        const counts = (data && data[id]) || {};
        const total = Object.values(counts).reduce((a, b) => a + (parseInt(b, 10) || 0), 0);
        rows.push({ title: link.textContent.trim(), href: link.getAttribute("href"), total });
      });
      const top = rows.filter((r) => r.total > 0).sort((a, b) => b.total - a.total).slice(0, 5);
      if (top.length < 3) return; // stay hidden until there's real signal
      const ol = document.getElementById("trending-list");
      const sec = document.getElementById("trending");
      if (!ol || !sec) return;
      ol.innerHTML = top
        .map(
          (r, i) =>
            `<li><a href="${esc(r.href)}"><span class="trending-rank">${i + 1}</span><span class="trending-title">${esc(r.title)}</span><span class="trending-count">${r.total}</span></a></li>`
        )
        .join("");
      sec.hidden = false;
    })();
  </script>

  <script src="../scripts/tracking.js"></script>
</Base>
