---
import Base from "../layouts/Base.astro";

const FORMSPREE_ENDPOINT = "https://formspree.io/f/xaqgzbwy";
---
<Base
  title="Contact — americawhat"
  description="Saw something that made you go wait, what? Send us the link, receipt, sign, or story."
  canonicalPath="/contact/"
>
  <a href="/" class="back-link">&larr; back to feed</a>

  <header class="page-head">
    <div class="page-eyebrow">Submit</div>
    <h1 class="page-title">Got a wait, what?</h1>
  </header>

  <article class="page-card">
    <p class="page-prose" style="margin-bottom:24px">
      Saw something that made you go <em>wait, what?</em> Send us the link, receipt, sign,
      screenshot, or story. Weird is good. Verifiable is better.
    </p>

    <form class="form" id="contact-form" data-endpoint={FORMSPREE_ENDPOINT} novalidate>
      <div class="form-field">
        <label class="form-label" for="name">Name</label>
        <input class="form-input" type="text" id="name" name="name" autocomplete="name" required />
      </div>

      <div class="form-field">
        <label class="form-label" for="email">Email</label>
        <input class="form-input" type="email" id="email" name="email" autocomplete="email" required />
      </div>

      <div class="form-field">
        <label class="form-label" for="link">Link / source <span class="form-opt">(optional, but it helps)</span></label>
        <input class="form-input" type="url" id="link" name="link" placeholder="https://…" />
      </div>

      <div class="form-field">
        <label class="form-label" for="message">What happened?</label>
        <textarea class="form-textarea" id="message" name="message" placeholder="The sign, the fee, the form, the rule — tell us what made you stop." required></textarea>
      </div>

      <div class="form-row">
        <div class="form-field">
          <label class="form-label" for="city">City <span class="form-opt">(optional)</span></label>
          <input class="form-input" type="text" id="city" name="city" autocomplete="address-level2" />
        </div>
        <div class="form-field">
          <label class="form-label" for="state">State <span class="form-opt">(optional)</span></label>
          <input class="form-input" type="text" id="state" name="state" autocomplete="address-level1" />
        </div>
      </div>

      <div class="form-field">
        <label class="form-label" for="photo">Screenshot / photo link <span class="form-opt">(optional)</span></label>
        <input class="form-input" type="url" id="photo" name="photo" placeholder="Paste a Google Drive, iCloud, Dropbox, Imgur, or social link" />
      </div>

      <div class="form-field">
        <label class="form-label" for="canPublish">Can we publish this?</label>
        <select class="form-input" id="canPublish" name="canPublish">
          <option value="yes">Yes, you may publish, edit, shorten, and caption my submission</option>
          <option value="no">No — just letting you know</option>
        </select>
      </div>

      <p class="form-note">
        Please don't send private personal information, full addresses, license plates,
        medical records, or anything you don't have permission to share.
      </p>

      <button class="form-submit" type="submit">Send it</button>

      <p class="form-status" id="form-status" role="status" aria-live="polite"></p>
    </form>
  </article>

  <script>
    const form = document.getElementById("contact-form");
    const statusEl = document.getElementById("form-status");
    const submitBtn = form?.querySelector(".form-submit");
    const endpoint = form?.getAttribute("data-endpoint");

    function setStatus(msg, kind) {
      if (!statusEl) return;
      statusEl.textContent = msg;
      statusEl.className = "form-status show " + kind;
    }

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!endpoint || endpoint.endsWith("REPLACE_ME")) {
        setStatus("This form isn't wired up yet. Email hello@americawhat.com in the meantime.", "err");
        return;
      }

      const data = {
        name: form.name.value.trim(),
        email: form.email.value.trim(),
        link: form.link.value.trim(),
        message: form.message.value.trim(),
        city: form.city.value.trim(),
        state: form.state.value.trim(),
        photo: form.photo.value.trim(),
        canPublish: form.canPublish.value,
      };

      if (!data.name || !data.email || !data.message) {
        setStatus("Name, email, and what happened are required.", "err");
        return;
      }

      submitBtn.disabled = true;
      const original = submitBtn.textContent;
      submitBtn.textContent = "Sending…";

      try {
        const res = await fetch(endpoint, {
          method: "POST",
          headers: { "Content-Type": "application/json", Accept: "application/json" },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          form.reset();
          setStatus("Got it. Thanks — we'll take a look. wait, what indeed.", "ok");
        } else {
          const body = await res.json().catch(() => null);
          const msg = body?.errors?.map((x) => x.message).join(", ");
          setStatus(msg || "Something went wrong. Try again, or email hello@americawhat.com.", "err");
        }
      } catch {
        setStatus("Couldn't reach the server. Check your connection and try again.", "err");
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = original;
      }
    });
  </script>
</Base>
