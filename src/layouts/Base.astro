---
const {
  title = "americawhat — wait, what",
  description = "The strange, the everyday, the deeply American. A curated feed of things that make you go wait, what.",
  canonicalPath = "/",
  ogType = "website",
  ogImage = "/og/default.png",
} = Astro.props;
import "../styles/global.css";
import { items } from "../lib/items.js";
const canonical = new URL(canonicalPath, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);
const slugs = items.map((i) => i.slug);
const randHref = slugs.length
  ? `/item/${slugs[Math.floor(Math.random() * slugs.length)]}/`
  : "/";
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate icon" href="/favicon.svg" />
  <link rel="mask-icon" href="/favicon.svg" color="#ff5468" />
  <meta name="theme-color" content="#0b1120" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="alternate" type="application/rss+xml" title="americawhat feed" href="/rss.xml" />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:image" content={ogImageUrl} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="preload"
    as="style"
    href="https://fonts.googleapis.com/css2?family=Anton&family=Archivo:ital,wght@0,400;0,600;0,700;0,800;1,500&display=swap"
  />
  <link
    href="https://fonts.googleapis.com/css2?family=Anton&family=Archivo:ital,wght@0,400;0,600;0,700;0,800;1,500&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <header class="site-head">
    <div class="site-head-inner">
      <a href="/" class="logo">america<b>what</b><span class="logo-q">?</span></a>
      <div class="head-right">
        <nav class="site-nav" aria-label="Primary">
          <a href="/about/">About</a>
          <a href="/contact/">Contact</a>
          <a href={randHref} class="nav-random" id="nav-random">Random</a>
        </nav>
        <span class="tagline">wait, what.</span>
      </div>
    </div>
  </header>
  <slot name="hero" />
  <main class="wrap">
    <slot />
  </main>
  <footer class="site-foot">
    <b>americawhat.com</b> — something's coming. probably confusing.<br />
    Got a "wait, what" of your own? <a href="mailto:hello@americawhat.com" style="color:var(--red-hot)">hello@americawhat.com</a>
    <nav class="foot-nav" aria-label="More">
      <a href="/about/">About</a>
      <a href="/contact/">Contact</a>
      <a href="/guidelines/">Submission Guidelines</a>
      <a href="/privacy/">Privacy</a>
      <a href="/terms/">Terms</a>
      <a href="/disclaimer/">Disclaimer</a>
      <a href="/rss.xml">RSS</a>
    </nav>
  </footer>
  <script is:inline define:vars={{ slugs }}>
    (function () {
      var el = document.getElementById("nav-random");
      if (!el || !slugs.length) return;
      el.addEventListener("click", function (e) {
        e.preventDefault();
        var s = slugs[Math.floor(Math.random() * slugs.length)];
        window.location.href = "/item/" + s + "/";
      });
    })();
  </script>
</body>
</html>
